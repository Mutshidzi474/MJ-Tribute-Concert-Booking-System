<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BC Concerts</title>

<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<link rel="stylesheet" href="/css/home.css">

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark animate__animated animate__fadeInDown">

  <div class="container">

    <a class="navbar-brand" href="/">
      MJ Tribute Concerts
    </a>

    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">

      <span class="navbar-toggler-icon"></span>

    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <ul class="navbar-nav mx-auto">

        <li class="nav-item animate__animated animate__fadeInLeft">
          <a class="nav-link" href="/">Home</a>
        </li>

        <li class="nav-item animate__animated animate__fadeInLeft" style="animation-delay: 0.4s;">
          <a class="nav-link" href="/auth/login">User Authentication</a>
        </li>

        <li class="nav-item animate__animated animate__fadeInLeft" style="animation-delay: 0.2s;">
          <a class="nav-link" href="/events">Event Management</a>
        </li>

        <li class="nav-item animate__animated animate__fadeInLeft" style="animation-delay: 1s;">
          <a class="nav-link" href="/dashboard">Booking & Dashboard</a>
        </li>

        <li class="nav-item animate__animated animate__fadeInLeft" style="animation-delay: 1s;">
          <a class="nav-link" href="/contact">Contact</a>
        </li>

      </ul>

      <span class="navbar-text text-white ml-auto animate__animated animate__fadeInLeft" style="animation-delay: 1.2s;">
        <% if (typeof user !== 'undefined' && user) { %>
          <strong><%= user.name %></strong>
          <small class="d-block" style="font-size: 0.85rem;"><%= user.email %></small>
        <% } else { %>
          Guest
        <% } %>
      </span>

    </div>

  </div>

</nav>

<!-- HERO SECTION -->
<div class="content">

  <div class="jumbotron jumbotron-fluid animate__animated animate__fadeIn">

    <div class="container">

      <h1 class="display-4 animate__animated animate__fadeInUp">
        Booking Dashboard
      </h1>

      <p class="lead animate__animated animate__fadeInUp">
        Manage your concert bookings and upcoming events
      </p>

    </div>

  </div>

</div>

<!-- DASHBOARD CONTENT -->
<div class="container my-5">

  <!-- DASHBOARD ACTIONS -->
  <div class="row mb-5 justify-content-center text-center">

    <div class="col-lg-4 col-md-6 col-sm-8 mb-3">
      <a href="/book-ticket" class="btn btn-dark btn-block btn-lg py-3">
        Book Ticket
      </a>
    </div>

    <div class="col-lg-4 col-md-6 col-sm-8 mb-3">
      <a href="/bookings" class="btn btn-danger btn-block btn-lg py-3">
        Cancel Booking
      </a>
    </div>

    <div class="col-lg-4 col-md-6 col-sm-8 mb-3">
      <a href="/download-tickets" class="btn btn-success btn-block btn-lg py-3">
        Download Tickets
      </a>
    </div>

  </div>
  <div class="row mb-5">

    <div class="col-md-4 mb-4">

      <div class="card shadow-lg animate__animated animate__fadeInUp">

        <div class="card-body text-center">

          <h5>Total Bookings</h5>

          <h2><%= typeof totalBookings !== 'undefined' ? totalBookings : 0 %></h2>

        </div>

      </div>

    </div>

    <div class="col-md-4 mb-4">

      <div class="card shadow-lg animate__animated animate__fadeInUp">

        <div class="card-body text-center">

          <h5>Upcoming Events</h5>

          <h2><%= typeof upcomingEvents !== 'undefined' ? upcomingEvents : 0 %></h2>

        </div>

      </div>

    </div>

    <div class="col-md-4 mb-4">

      <div class="card shadow-lg animate__animated animate__fadeInUp">

        <div class="card-body text-center">

          <h5>Tickets Purchased</h5>

          <h2><%= typeof ticketsPurchased !== 'undefined' ? ticketsPurchased : 0 %></h2>

        </div>

      </div>

    </div>

  </div>

  <!-- UPCOMING EVENTS -->
  <div class="mb-5 animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3 class = "title">Upcoming Events</h3>
      <span class="badge badge-pill badge-dark"><%= typeof upcomingEvents !== 'undefined' ? upcomingEvents : (Array.isArray(events) ? events.length : 0) %> events</span>
    </div>

    <div class="row">
      <% if (Array.isArray(events) && events.length) { %>
        <% events.forEach(event => { %>
          <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h5 class="card-title mb-0"><%= event.title %></h5>
                  <span class="badge badge-secondary"><%= new Date(event.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                </div>
                <p class="text-muted mb-2"><small><strong>Location:</strong> <%= event.location %></small></p>
                <p class="mb-2"><%= event.description %></p>
                <ul class="list-group list-group-flush mb-3">
                  <li class="list-group-item px-0 py-2"><strong>Category:</strong> <%= event.category || 'General' %></li>
                  <li class="list-group-item px-0 py-2"><strong>Remaining tickets:</strong> <%= event.ticketAvailable != null ? event.ticketAvailable : 'N/A' %></li>
                  <li class="list-group-item px-0 py-2"><strong>Price:</strong> <%= event.price != null ? event.price : 'TBD' %> ZAR</li>
                </ul>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12">
          <div class="alert alert-info">No upcoming events available.</div>
        </div>
      <% } %>
    </div>

  </div>

  <!-- BOOKINGS TABLE -->
  <div class="card shadow-lg animate__animated animate__fadeIn">

    <div class="card-body">

      <h3 class="mb-4">
        Recent Bookings
      </h3>

      <table class="table table-striped">

        <thead class="thead-dark">

          <tr>
            <th>Concert</th>
            <th>Date</th>
            <th>Tickets</th>
            <th>Status</th>
          </tr>

        </thead>

        <tbody>
          <% if (bookings && bookings.length > 0) { %>
            <% bookings.forEach(booking => { %>
              <tr>
                <td><%= booking.event ? booking.event.title : booking.eventName || 'Unknown Event' %></td>
                <td><%= booking.event ? new Date(booking.event.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : 'N/A' %></td>
                <td><%= booking.tickets %></td>
                <td><%= booking.status %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="4" class="text-center">No bookings found.</td>
            </tr>
          <% } %>
        </tbody>

      </table>

    </div>

  </div>

</div>

<!-- FOOTER -->
<footer class="bg-dark text-white py-3">

  <div class="container">

    <div class="row">

      <div class="col-12 text-center">

        <p>
          &copy; 2024 Belgium Campus Concerts. All rights reserved.
        </p>

      </div>

    </div>

  </div>

</footer>

<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>

<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

</body>
</html>
