<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Enquiries</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<%- include('partials/navbar') %>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Customer Enquiries</h1>
        <a href="/dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error %>
            <button type="button" class="close" data-dismiss="alert">
                <span>&times;</span>
            </button>
        </div>
    <% } %>

    <% if (enquiries && enquiries.length > 0) { %>
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% enquiries.forEach(enquiry => { %>
                        <tr>
                            <td><%= enquiry.name %></td>
                            <td><a href="mailto:<%= enquiry.email %>"><%= enquiry.email %></a></td>
                            <td><%= enquiry.phone || 'N/A' %></td>
                            <td><%= enquiry.subject %></td>
                            <td>
                                <% if (enquiry.status === 'new') { %>
                                    <span class="badge badge-danger">New</span>
                                <% } else if (enquiry.status === 'read') { %>
                                    <span class="badge badge-warning">Read</span>
                                <% } else if (enquiry.status === 'replied') { %>
                                    <span class="badge badge-success">Replied</span>
                                <% } %>
                            </td>
                            <td><%= new Date(enquiry.createdAt).toLocaleDateString() %></td>
                            <td>
                                <a href="/admin/enquiries/<%= enquiry._id %>" class="btn btn-sm btn-info">View</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="alert alert-info">
            <strong>No enquiries yet!</strong> Customer enquiries will appear here.
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>

<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

</body>
</html>
