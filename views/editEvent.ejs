<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enquiry Details</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<%- include('partials/navbar') %>

<div class="container py-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0"><%= enquiry.subject %></h3>
                        <div>
                            <% if (enquiry.status === 'new') { %>
                                <span class="badge badge-danger">New</span>
                            <% } else if (enquiry.status === 'read') { %>
                                <span class="badge badge-warning">Read</span>
                            <% } else if (enquiry.status === 'replied') { %>
                                <span class="badge badge-success">Replied</span>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">From:</h6>
                            <p><strong><%= enquiry.name %></strong></p>
                            <p>
                                <a href="mailto:<%= enquiry.email %>"><%= enquiry.email %></a>
                            </p>
                            <% if (enquiry.phone) { %>
                                <p>
                                    <a href="tel:<%= enquiry.phone %>"><%= enquiry.phone %></a>
                                </p>
                            <% } %>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Date:</h6>
                            <p><%= new Date(enquiry.createdAt).toLocaleString() %></p>
                        </div>
                    </div>

                    <hr>

                    <div class="mb-4">
                        <h6 class="text-muted">Message:</h6>
                        <div class="alert alert-light border">
                            <p><%= enquiry.message %></p>
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-md-12">
                            <h6 class="text-muted mb-3">Status Management:</h6>
                            <div class="btn-group" role="group">
                                <% if (enquiry.status !== 'read') { %>
                                    <form action="/admin/enquiries/<%= enquiry._id %>/read" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-warning">Mark as Read</button>
                                    </form>
                                <% } %>

                                <% if (enquiry.status !== 'replied') { %>
                                    <form action="/admin/enquiries/<%= enquiry._id %>/replied" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-success">Mark as Replied</button>
                                    </form>
                                <% } %>

                                <form action="/admin/enquiries/<%= enquiry._id %>/delete" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this enquiry?');">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer text-muted">
                    <a href="/admin/enquiries" class="btn btn-secondary">Back to Enquiries</a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

</body>
</html>
