<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/global.css">
</head>
<body>
<%- include('partials/navbar') %>
<div class="container py-5">
    <h1 class="mb-4">Admin Dashboard</h1>
    <p class="lead">Welcome to admin event management.</p>
    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Events</h5>
                    <p class="card-text">Manage concerts, capacity, availability and pricing.</p>
                    <a href="/events" class="btn btn-primary">Manage Events</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Users</h5>
                    <p class="card-text">View and manage registered users.</p>
                    <a href="/users" class="btn btn-secondary">Manage Users</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Event Count</h5>
                    <p class="card-text">Current total events: <strong><%= totalEvents %></strong></p>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
